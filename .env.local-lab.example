# =============================================================================
# InteLIS Insights — environment for the BUNDLED LOCAL MySQL setup.
#
# Use this template when the client should NOT install or run MySQL
# themselves and you want `docker compose up -d` to bring up MySQL too,
# seeded from a dump in ./mysql-init/.
#
#   cp .env.local-lab.example .env
#   cp <your-dump>.sql.gz mysql-init/01-intelis-dump.sql.gz
#   # fill in the <change-me> values below
#   docker compose up -d
#
# For the standard deployment against an EXISTING InteLIS MySQL server,
# use `.env.example` instead.
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=production
APP_PORT=3000

# Auth.js — REQUIRED. Generate with: `openssl rand -base64 32`
AUTH_SECRET=<change-me>
AUTH_URL=http://localhost:3000

# --- App database (Postgres, managed by this service) -----------------------
POSTGRES_PASSWORD=<change-me>
APP_DB_URL=postgres://intelis:<same-as-POSTGRES_PASSWORD>@postgres:5432/intelis_insights

# --- Lab database (BUNDLED InteLIS MySQL — READ-ONLY) -----------------------
# Points at the local `intelis-mysql` container from
# docker-compose.local-lab.yml. The container imports any *.sql / *.sql.gz
# from ./mysql-init/ on first boot, then 99-create-readonly-user.sh creates
# the intelis_reader user with GRANT SELECT on LAB_DB_NAME.
#
# LAB_DB_NAME: any name. For phpMyAdmin dumps without CREATE DATABASE / USE
# (the common InteLIS export), the entrypoint creates this DB and imports
# the dump into it. For dumps that contain `USE foo;`, set LAB_DB_NAME=foo
# (exact match) so the reader-user grant lands on the right database.
LAB_DB_HOST=intelis-mysql
LAB_DB_PORT=3306
LAB_DB_NAME=vlsm
LAB_DB_USER=intelis_reader
LAB_DB_PASSWORD=<change-me>

# Local MySQL container — root password (used during dump import and to
# grant SELECT to the reader user) and the host port it's exposed on.
LOCAL_LAB_MYSQL_ROOT_PASSWORD=<change-me>
LOCAL_LAB_MYSQL_PORT=3307

# REQUIRED for this setup: makes `docker compose up -d` automatically
# layer the local-lab override on top of the base compose file. Without
# these two lines, the `intelis-mysql` service is not loaded.
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:docker-compose.local-lab.yml

# --- Qdrant vector DB --------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=intelis_insights

# --- LLM provider ------------------------------------------------------------
# One of:
#   openai | anthropic | google     — major cloud providers
#   mistral                          — Mistral AI (cloud)
#   deepseek                         — DeepSeek (cloud, low-cost OpenAI-compat)
#   groq                             — Groq (cloud, fast inference, OpenAI-compat)
#   openai_compatible                — generic: Together, Fireworks, OpenRouter,
#                                       self-hosted vLLM / LiteLLM, etc.
#   ollama                           — local / offline
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# Secondary slot used for cheap auxiliary calls (chart-type suggestion
# fallback). On providers with a real "small" tier (gpt-4o-mini,
# claude-haiku, gemini-flash) this is a meaningful cost lever; on
# providers without one (DeepSeek), set it to the same as LLM_MODEL.
LLM_MODEL_FAST=gpt-4o-mini

# Provide ONLY the key for your chosen LLM_PROVIDER.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# For LLM_PROVIDER=openai_compatible — point at any OpenAI-compatible API.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Ollama — only needed if LLM_PROVIDER=ollama or EMBEDDINGS_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Embeddings --------------------------------------------------------------
# One of: openai | mistral | openai_compatible | ollama
# Switching providers requires re-ingesting the corpus (different vector dim).
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# --- Observability — LangFuse (optional) ------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Admin user seeding (optional) ------------------------------------------
# If both EMAIL and PASSWORD are set, the `init` container will create
# (or rotate the password of) an admin user with national-level access.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
