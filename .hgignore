# Mercurial ignore file (.hgignore)
# Use glob syntax for pattern matching

syntax: glob

# Configuration files with sensitive data
config/app.php
config/db.php

# Generated schema file
var/schema.json

# RAG snippets (generated)
corpus/snippets.jsonl

# Composer dependencies
vendor/*
vendor/**

# Common PHP development files
*.log
*.tmp
*.cache

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary and build files
tmp/
temp/
build/
dist/

# Environment files
.env
.env.local
.env.production

# RAG/Qdrant generated data
qdrant_storage/**

# Cache
var/cache/**

# IDE security plugin output
.github/instructions/snyk_rules.instructions.md
