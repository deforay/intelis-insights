# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# generated RAG artifacts
/corpus/*.json
/corpus/*.jsonl

# local/demo InteLIS MySQL dumps (never commit lab data)
/mysql-init/*.sql
/mysql-init/*.sql.gz
/mysql-init/*.dump
/mysql-init/*.dump.gz

# test artifacts
/playwright-report/
/test-results/

# misc local
/qdrant_storage/

# local agent / AI tool files (project-scoped, not for VCS)
/CLAUDE.md
/.claude/
/.cursor/
/.continue/
/.aider*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
