# Port mapping for the PHP app
APP_PORT=8080
APP_ENV=production

# Database connection for the app and schema export
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vlsm
DB_USER=db_user
DB_PASSWORD=db_password

# LLM provider defaults (pick one: openai | ollama | anthropic)
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=codegemma:7b-instruct

# RAG service
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=intelis_rag
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional: enable Traefik reverse proxy with Let's Encrypt (set true + domain + email)
ENABLE_TRAEFIK=false
APP_DOMAIN=app.example.com
TRAEFIK_ACME_EMAIL=admin@example.com
