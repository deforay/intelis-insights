# =============================================================================
# InteLIS Insights — environment configuration
#
# Copy this file to `.env` and fill in the values for your deployment.
#   cp .env.example .env
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=production
APP_PORT=3000

# Auth.js — REQUIRED. Generate with: `openssl rand -base64 32`
AUTH_SECRET=
# Public URL the app is served from (used for OAuth redirects, cookies)
AUTH_URL=http://localhost:3000

# --- App database (Postgres, managed by this service) -----------------------
# When using docker-compose, the app talks to the `postgres` service.
# POSTGRES_PASSWORD is read by the postgres container; APP_DB_URL by the app.
POSTGRES_PASSWORD=change-me
APP_DB_URL=postgres://intelis:change-me@localhost:5432/intelis_insights

# --- Lab database (external InteLIS MySQL — READ-ONLY) ----------------------
# These point at the country's existing InteLIS deployment. Provision a
# read-only MySQL user (`GRANT SELECT`) and put its credentials here.
#
# Hostname guidance:
#   - MySQL on a remote server:          use its hostname or IP
#   - MySQL on the Docker host (Mac/Win): use `host.docker.internal`
#   - MySQL on the Docker host (Linux):  use `host.docker.internal` AND
#       uncomment the `extra_hosts` blocks in docker-compose.yml
#   - MySQL in another container:        use that container's service name
#   - Bundled local MySQL override:      use `intelis-mysql`
LAB_DB_HOST=
LAB_DB_PORT=3306
LAB_DB_NAME=
LAB_DB_USER=
LAB_DB_PASSWORD=

# Optional local/demo InteLIS MySQL container.
# Uncomment COMPOSE_* to make `docker compose up -d` include the local MySQL
# override on macOS, Linux, and Windows.
# COMPOSE_PATH_SEPARATOR=:
# COMPOSE_FILE=docker-compose.yml:docker-compose.local-lab.yml
# Put an approved .sql or .sql.gz dump in ./mysql-init before first startup.
LOCAL_LAB_MYSQL_ROOT_PASSWORD=
LOCAL_LAB_MYSQL_PORT=3307

# --- Qdrant vector DB --------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=intelis_insights

# --- LLM provider ------------------------------------------------------------
# One of:
#   openai | anthropic | google     — major cloud providers
#   mistral                          — Mistral AI (cloud)
#   deepseek                         — DeepSeek (cloud, low-cost OpenAI-compat)
#   groq                             — Groq (cloud, fast inference, OpenAI-compat)
#   openai_compatible                — generic: Together, Fireworks, OpenRouter,
#                                       self-hosted vLLM / LiteLLM, etc.
#   ollama                           — local / offline
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
# Secondary slot used for cheap auxiliary calls (chart-type suggestion
# fallback). On providers with a real "small" tier (gpt-4o-mini,
# claude-haiku, gemini-flash) this is a meaningful cost lever; on
# providers without one (DeepSeek), set it to the same as LLM_MODEL.
LLM_MODEL_FAST=gpt-4o-mini

# Provide ONLY the key for your chosen LLM_PROVIDER.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# For LLM_PROVIDER=openai_compatible — point at any OpenAI-compatible API.
# Examples:
#   Together   https://api.together.xyz/v1
#   Fireworks  https://api.fireworks.ai/inference/v1
#   OpenRouter https://openrouter.ai/api/v1
#   vLLM       http://your-host:8000/v1
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Ollama — only needed if LLM_PROVIDER=ollama or EMBEDDINGS_PROVIDER=ollama.
# When using docker-compose --profile offline, this defaults to the bundled
# `ollama` service. For an external Ollama, point to it explicitly.
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Embeddings --------------------------------------------------------------
# One of: openai | mistral | openai_compatible | ollama
# Switching providers requires re-ingesting the corpus (different vector dim).
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# --- Observability — LangFuse (optional) ------------------------------------
# Self-host: docker compose --profile observability up, then create a project
# and paste the keys below. Or use LangFuse Cloud (https://cloud.langfuse.com).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Admin user seeding (optional) ------------------------------------------
# If both EMAIL and PASSWORD are set, the `init` container will create
# (or rotate the password of) an admin user with national-level access.
# Leave blank to skip — you can run `npm run seed:admin` manually later.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
