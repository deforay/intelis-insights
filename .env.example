# =============================================================================
# InteLIS Insights — environment configuration
#
# Copy this file to `.env` and fill in the values for your deployment.
#   cp .env.example .env
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=production
APP_PORT=3000

# Auth.js — REQUIRED. Generate with: `openssl rand -base64 32`
AUTH_SECRET=
# Public URL the app is served from (used for OAuth redirects, cookies)
AUTH_URL=http://localhost:3000

# --- App database (Postgres, managed by this service) -----------------------
# When using docker-compose, the app talks to the `postgres` service.
# POSTGRES_PASSWORD is read by the postgres container; APP_DB_URL by the app.
POSTGRES_PASSWORD=change-me
APP_DB_URL=postgres://intelis:change-me@localhost:5432/intelis_insights

# --- Lab database (external InteLIS MySQL — READ-ONLY) ----------------------
# These point at the country's existing InteLIS deployment. Provision a
# read-only MySQL user (`GRANT SELECT`) and put its credentials here.
LAB_DB_HOST=
LAB_DB_PORT=3306
LAB_DB_NAME=
LAB_DB_USER=
LAB_DB_PASSWORD=

# --- Qdrant vector DB --------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=intelis_insights

# --- LLM provider ------------------------------------------------------------
# One of: openai | anthropic | google | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MODEL_INTENT=gpt-4o-mini

# Provide ONLY the key for your chosen LLM_PROVIDER.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Ollama — only needed if LLM_PROVIDER=ollama or EMBEDDINGS_PROVIDER=ollama.
# When using docker-compose --profile offline, this defaults to the bundled
# `ollama` service. For an external Ollama, point to it explicitly.
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Embeddings --------------------------------------------------------------
# One of: openai | ollama. Switching providers requires re-ingesting the
# corpus (different vector dimension).
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small

# --- Observability — LangFuse (optional) ------------------------------------
# Self-host: docker compose --profile observability up, then create a project
# and paste the keys below. Or use LangFuse Cloud (https://cloud.langfuse.com).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
